# ──────────────────────────────────────────────
# NotCast — Ortam Değişkenleri Şablonu
# Kopyala: cp .env.example apps/server/.env
# ──────────────────────────────────────────────

# ──────── Database ────────
DATABASE_URL=postgresql://notcast:notcast_password@localhost:5432/notcast

# ──────── Redis ────────
REDIS_URL=redis://localhost:6379

# ──────── Auth ────────
# Üret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<rastgele-64-karakter-hex>
JWT_REFRESH_SECRET=<rastgele-64-karakter-hex>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ──────── Storage (MinIO/S3) ────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=notcast-uploads
S3_REGION=us-east-1
# Production için: AWS_S3 veya başka bir S3-uyumlu servis
# S3_ENDPOINT=https://s3.amazonaws.com

# ──────── ElevenLabs ────────
ELEVENLABS_API_KEY=<elevenlabs-api-key>
ELEVENLABS_DEFAULT_MODEL=eleven_multilingual_v2
ELEVENLABS_MAX_CHUNK_SIZE=5000

# ──────── Claude (Anthropic) ────────
ANTHROPIC_API_KEY=<anthropic-api-key>
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ──────── Google Cloud Vision ────────
GOOGLE_CLOUD_PROJECT_ID=<gcp-project-id>
GOOGLE_APPLICATION_CREDENTIALS=./keys/google-service-account.json

# ──────── App ────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ──────── Frontend (Next.js) ────────
# apps/web/.env.local dosyasına ekle
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ──────── Email (Opsiyonel) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<gmail-adresi>
SMTP_PASS=<gmail-uygulama-sifresi>
EMAIL_FROM="NotCast <noreply@notcast.app>"

# ──────── Rate Limiting ────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
UPLOAD_RATE_LIMIT_MAX=20

# ──────── File Upload ────────
MAX_IMAGE_SIZE_MB=10
MAX_PDF_SIZE_MB=20
MAX_TEXT_SIZE_MB=1

# ──────── Bull Queue ────────
BULL_CONCURRENCY=3
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY_MS=5000
